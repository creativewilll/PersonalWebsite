{
  "name": "williamspurlock-portfolio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/validate-blog-frontmatter.mjs && node scripts/generate-sitemap.mjs",
    "build": "vite build",
    "build:cf": "node scripts/validate-blog-frontmatter.mjs && node scripts/generate-sitemap.mjs && node scripts/optimize-images.mjs --quiet && vite build && npx playwright install chromium && node scripts/prerender.mjs",
    "build:prod": "npm run build:cf",
    "build:fast": "node scripts/validate-blog-frontmatter.mjs && node scripts/generate-sitemap.mjs && vite build && node scripts/prerender.mjs --skip",
    "build:fresh": "node scripts/validate-blog-frontmatter.mjs && node scripts/generate-sitemap.mjs && vite build && node scripts/prerender.mjs --no-cache",
    "prerender:clear-cache": "rm -rf .prerender-cache",
    "optimize:images": "node scripts/optimize-images.mjs",
    "sitemap": "node scripts/generate-sitemap.mjs",
    "validate-blog": "node scripts/validate-blog-frontmatter.mjs",
    "deploy": "echo 'Deploys run automatically on Cloudflare Workers Builds via git push to main. For an emergency manual deploy, run: npm run deploy:manual' && exit 0",
    "deploy:manual": "npm run build:cf && wrangler deploy",
    "lint": "eslint .",
    "preview": "vite preview",
    "security-check": "npx security-check",
    "process-blog": "ts-node scripts/process-blog-posts.ts"
  },
  "dependencies": {
    "@playwright/test": "^1.41.2",
    "@tailwindcss/typography": "^0.5.10",
    "@types/dompurify": "^3.0.5",
    "@types/marked": "^5.0.2",
    "@types/matter-js": "^0.19.8",
    "clsx": "^2.1.1",
    "dompurify": "^3.2.5",
    "framer-motion": "^11.0.3",
    "gray-matter": "^4.0.3",
    "inquirer": "^8.2.6",
    "lucide-react": "^0.330.0",
    "marked": "^15.0.7",
    "matter-js": "^0.19.0",
    "mermaid": "^11.15.0",
    "react": "^18.2.0",
    "react-calendly": "^4.1.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^2.0.4",
    "react-intersection-observer": "^9.5.3",
    "react-router-dom": "^6.22.0",
    "slugify": "^1.6.6",
    "tailwind-merge": "^3.6.0",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@eslint/js": "^8.56.0",
    "@types/inquirer": "^8.2.6",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "cursor-tools": "latest",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "globals": "^13.24.0",
    "postcss": "^8.4.33",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "terser": "^5.27.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^7.0.0",
    "vite": "^6.2.5",
    "wrangler": "^4.94.0"
  },
  "description": "",
  "main": "eslint.config.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BigRock12123/PersonalWebsite.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/BigRock12123/PersonalWebsite/issues"
  },
  "homepage": "https://github.com/BigRock12123/PersonalWebsite#readme"
}
